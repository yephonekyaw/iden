# Verification Server — environment template.
# Copy to `.env` and fill in IDEN_DATABASE_URL at minimum.

# --- Required ---------------------------------------------------------------

# Postgres + pgvector. Use the asyncpg driver.
IDEN_DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/iden

# --- Storage ----------------------------------------------------------------

# Local mirror directory: local_store/<identity_id>/{face.jpg,record.json}
IDEN_LOCAL_STORAGE_DIR=local_store

# --- Face pipeline ----------------------------------------------------------

IDEN_INSIGHTFACE_MODEL=buffalo_l
IDEN_DETECTOR_SIZE=640
IDEN_EMBEDDING_DIM=512
IDEN_MATCH_THRESHOLD=0.50

# --- Request limits & quality gating ---------------------------------------

IDEN_MAX_IMAGES_PER_REQUEST=8
IDEN_MAX_IMAGE_BYTES=10485760
IDEN_MAX_IMAGE_SIDE=1280
IDEN_MIN_DET_SCORE=0.6
IDEN_MIN_FACE_PIXELS=60

# --- App --------------------------------------------------------------------

# JSON list. Tighten in production, e.g. ["https://app.example.com"].
IDEN_ALLOWED_ORIGINS=["*"]
IDEN_LOG_LEVEL=INFO
